# SPDX-License-Identifier: GPL-3.0-or-later
#
# Pinned configuration for the Linux kernel dogfooding target (Stage 4 scale
# validation). A dogfooding configuration is (base image digest, target source
# revision, target build type); all are pinned so the Stage 4 checks stay
# stable (dogfood-pinned-target). Sourced by run.sh; values are also consumed
# by the target Containerfile via podman build --build-arg.
#
# This is a LARGE scale-validation target: an x86_64 defconfig build is several
# thousand translation units, used to prove the target-agnostic Stage 4 checks
# (--invariants / --determinism / --replay) hold at kernel scale.

# Validation mode: 'none' - no committed golden and no oracle. The kernel is
# not a CMake project (no CMAKE_EXPORT_COMPILE_COMMANDS oracle), and a golden
# CDB of tens of thousands of entries is impractical to commit and review. This
# target is therefore run ONLY with the Stage 4 checks; run.sh refuses a
# no-mode run for a VALIDATION=none target.
VALIDATION="none"

# Pinned base image: the same digest zlib/curl use (this IS fedora:44, the
# devcontainer base). An unpinned base would let a package update change the
# compiler under the scale checks.
BASE_IMAGE="registry.fedoraproject.org/fedora@sha256:3baf5f0dededfd939eb8f0b271ff8ad17bdb381cdd5768bd7d6f45bba795aa62"

# Pinned kernel source. The URL/SHA256 are HARDCODED in the Containerfile (the
# source revision is part of the pinned configuration, not a caller arg); this
# variable is documentation only.
# shellcheck disable=SC2034
KERNEL_VERSION="6.12.94"

# Pinned build type. An x86_64 'make defconfig' build: a fixed, architecture-
# pinned configuration so the set of compiled translation units is reproducible
# across runs (required for --determinism).
# shellcheck disable=SC2034
BUILD_TYPE="defconfig-x86_64"

# Fixed in-container build path (dogfood-fixed-paths). The kernel builds
# IN-TREE (Kbuild emits objects next to sources, or under an O= dir; we use the
# in-tree default), so source, build, and objects all share /src. A fixed path
# keeps absolute paths in 'directory' reproducible across the two determinism
# runs.
SRC_DIR="/src"
# shellcheck disable=SC2034
BUILD_DIR="/src"
# shellcheck disable=SC2034
OBJECTS_DIR="/src"

# Object-count instrument for the entry-count invariant (dogfood-invariants).
#
# A post-build `find /src -name '*.o' | wc -l` is the WRONG instrument for the
# kernel: Kbuild aggregates objects into per-directory built-in.a archives and
# linked .o files, so the surviving *.o set is a poor proxy for "C sources
# actually compiled". A `make -Bn` dry-run is also unreliable here: the kernel's
# recursive Kbuild does not enumerate the full compile set in dry-run (it needs
# generated prerequisites a dry-run never makes), so it counts ~0. (The harness
# degrades gracefully if this instrument yields 0 - the structural invariants
# still run, only the entry-count cross-check is skipped.)
#
# Instead we count Kbuild's OWN per-compile command files, independent of Bear:
# for every compiled object `foo.o` Kbuild writes a hidden `.foo.o.cmd` file
# recording the exact command. Compile commands carry the ` -c ` flag; the
# aggregate/link `.cmd` files (ar/ld) do not, and archives are `.a.cmd` (not
# `.o.cmd`). So counting `.*.o.cmd` files whose recorded command contains ` -c `
# yields one count per C compile, directly comparable to Bear's one-entry-per-
# compile capture. These files persist after the build (cleanup-independent) and
# are produced by Kbuild, not Bear. OBJECT_TOLERANCE_PCT absorbs the residual
# slack (host-tool compiles, a handful of generated-source compiles, etc.).
# shellcheck disable=SC2034
OBJECT_COUNT_CMD="find /src -name '.*.o.cmd' 2>/dev/null -exec grep -lF -- ' -c ' {} + 2>/dev/null | wc -l"

# Tolerance percent for the entry-count band (--expected-objects N --tolerance
# OBJECT_TOLERANCE_PCT). The dry-run count and Bear's capture are produced by
# two different mechanisms (Kbuild's printed recipe set vs Bear's intercepted
# exec set), so they are close but not identical: recipes whose command line is
# computed at build time, host-tool compiles, and conditional rules can shift
# the two by a few percent. 15% is wide enough to absorb that structural slack
# at tens-of-thousands scale while still catching a gross entry drop or a
# systematic duplication (which would move the count by far more than 15%).
# shellcheck disable=SC2034
OBJECT_TOLERANCE_PCT="15"

# Per-target preflight minimum free disk on the podman graphroot, in KiB
# (dogfood-preflight). A kernel defconfig build needs several GiB of object
# tree on top of the base + target images and the ~1.4 GiB extracted source;
# --determinism builds it TWICE (two fresh containers). ~12 GiB is a generous
# floor that keeps the run from starting on a near-full disk.
MIN_FREE_KIB="12582912"

# The build command run INSIDE the target container, wrapped by Bear.
#
# Phase 1: `make defconfig` (NOT wrapped by Bear - configuration is not a
# compile) produces a fixed, architecture-pinned .config for x86_64 so the set
# of compiled translation units is reproducible.
#
# Phase 2: the real `make` build, wrapped by Bear -> Bear's capture at
# /out/compile_commands.json. ARCH=x86_64 is pinned for determinism.
#
# INJECT_CFLAGS is the determinism self-test hook (dogfood-determinism): empty
# on every normal run and on determinism run 1, it carries a perturbing flag on
# determinism run 2 under --inject-fault. The kernel honors KCFLAGS, which is
# appended to the compiler command line for kernel objects, so the flag lands
# in the recorded arguments and the two captures diverge, showing the
# determinism check FAIL. /src is fresh each run (a new container).
# shellcheck disable=SC2034
TARGET_BUILD_CMD='mkdir -p /out && cd /src && make ARCH=x86_64 defconfig && ${RPROF_PREFIX:-} bear --output /out/compile_commands.json -- make ARCH=x86_64 -j"$(nproc)" KCFLAGS="${INJECT_CFLAGS:-}"'
