# SPDX-License-Identifier: GPL-3.0-or-later
#
# Pinned configuration for the FFmpeg dogfooding target (Stage 4, scale).
# FFmpeg is a MIDSIZE scale-validation target (~1945 translation units, between
# curl's ~221 and the kernel's thousands) that exercises a build system the
# harness did not previously cover: FFmpeg's HAND-WRITTEN POSIX-sh `configure`
# (not autotools, not CMake). A dogfooding configuration is (base image digest,
# target source revision, target build type); all are pinned so the checks stay
# stable (dogfood-pinned-target). Sourced by run.sh; SRC_DIR is also consumed by
# the target Containerfile via podman build --build-arg.

# Validation mode for this target: 'none'. A scale target has no committed
# golden (too large to bless and review) and no CMake oracle (FFmpeg does not
# use CMake), so it is run ONLY with the target-agnostic Stage 4 checks
# (--invariants / --determinism / --replay). run.sh dispatches on this selector.
# shellcheck disable=SC2034
VALIDATION="none"

# Pinned base image: the same digest zlib/curl use (this IS fedora:44, the
# devcontainer base). An unpinned base would let a package update change the
# compiler under the fixed checks and produce phantom diffs.
# shellcheck disable=SC2034
BASE_IMAGE="registry.fedoraproject.org/fedora@sha256:3baf5f0dededfd939eb8f0b271ff8ad17bdb381cdd5768bd7d6f45bba795aa62"

# Fixed in-container build path (dogfood-fixed-paths). FFmpeg builds IN-TREE by
# default (objects land next to their sources under /src); its configure has no
# out-of-tree mode worth the extra moving parts, so source, objects, and build
# dir are all this one fixed path. A fixed path keeps absolute paths in
# 'directory' reproducible across runs (so the determinism check needs no
# normalization).
# shellcheck disable=SC2034
SRC_DIR="/src"

# Object-count instrument for the entry-count invariant (dogfood-invariants).
# FFmpeg's in-tree make leaves EVERY object on disk under /src (it does not
# delete PIC duplicates the way zlib does, and it compiles each source exactly
# once - no shared/static double-compile the way curl does), so the DEFAULT
# instrument - a post-build `find $OBJECTS_DIR -name '*.o' | wc -l` - is exact.
# Verified empirically on a real build: find=1945, make-graph=1945, and Bear's
# entry_count=1945 all agree exactly, so FFmpeg does NOT override
# OBJECT_COUNT_CMD. (Contrast zlib, which deletes its PIC objects and must count
# make's dependency graph instead.)
# shellcheck disable=SC2034
OBJECTS_DIR="/src"

# Build directory passed to the replay sampler (dogfood-replay) as
# `cdb-compare sample --build-dir`. FFmpeg builds in-tree, so its build dir IS
# /src.
# shellcheck disable=SC2034
BUILD_DIR="/src"

# Tolerance percent for the entry-count band
# (--expected-objects N --tolerance OBJECT_TOLERANCE_PCT). The find instrument
# matched Bear's entry count EXACTLY on a real build (1945 == 1945), so the band
# only needs to absorb an incidental build-system object across FFmpeg releases.
# 10% is deliberately small headroom: wide enough that a stray generated .o does
# not false-fail, tight enough that a real entry drop or duplication still trips
# the check.
# shellcheck disable=SC2034
OBJECT_TOLERANCE_PCT="10"

# Per-target preflight minimum free disk on the podman graphroot, in KiB
# (dogfood-preflight). FFmpeg needs more than curl: base + target images plus a
# full in-tree object tree of ~1945 objects. ~4 GiB is a safe floor.
# shellcheck disable=SC2034
MIN_FREE_KIB="4194304"

# The build command run INSIDE the target container. Two phases:
#
#  1. CONFIGURE (NOT wrapped by Bear - FFmpeg's configure is a sh script that
#     probes the toolchain and writes config.mak; it is not a compile). The
#     flags pick a LARGE internal codebase with NO external library deps and NO
#     assembler toolchain so the image stays minimal and reproducible:
#       --disable-autodetect  do not link any auto-detected external library
#       --disable-doc         skip documentation (no texi2html/perl-doc deps)
#       --disable-programs    library TUs only - no ffmpeg/ffprobe/ffplay CLIs
#                             (keeps the count to the codecs/formats themselves)
#       --disable-asm         build pure C - no nasm/yasm, no .S assembly, so
#                             the only toolchain needed is gcc + make + perl
#     This still compiles ~1945 C translation units across libav*/libsw*.
#
#  2. BUILD wrapped by Bear -> Bear's capture at /out/compile_commands.json.
#
# INJECT_CFLAGS is the determinism self-test hook (dogfood-determinism): empty
# on every normal run and on determinism run 1, it carries a perturbing flag on
# determinism run 2 under --inject-fault. FFmpeg's configure accepts
# `--extra-cflags=...`, which appends to the recorded compiler arguments, so the
# fault lands in the capture and the two builds diverge - showing the
# determinism check FAIL. Empty `--extra-cflags=""` is a harmless no-op on a
# normal run. /src is fresh each run (a new container), so configure re-runs and
# the flag takes effect.
# shellcheck disable=SC2034
TARGET_BUILD_CMD='mkdir -p /out && cd /src && ./configure --disable-autodetect --disable-doc --disable-programs --disable-asm --extra-cflags="${INJECT_CFLAGS:-}" && bear --output /out/compile_commands.json -- make -j"$(nproc)"'
